# Conexion a PostgreSQL — se arma automaticamente desde estas 5 variables
# (mismo patron que db/config/db_config.py: create_db_engine). La contrasena
# se escapa automaticamente para soportar caracteres especiales.
DB_HOST=localhost
DB_PORT=5432
DB_USER=readonly_user
DB_PASSWORD=password
DB_NAME=etl_db

# Conexion de metadatos (app_users, etl_registry). Si se omite, usa la de arriba.
APP_METADATA_DATABASE_URL=

# Alternativa avanzada: URL completa. Si se define, tiene prioridad sobre
# DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME.
DATABASE_URL=

API_ENV=development
API_PORT=8000
LOG_LEVEL=INFO

# Seguridad
AUTH_ALLOWED_EMAIL_DOMAIN=lazarza.com.mx
PASSWORD_HASH_ALGORITHM=bcrypt
AUTH_SECRET_KEY=change-me-in-production
AUTH_TOKEN_EXPIRE_MINUTES=480

# Schema donde viven las tablas de ejecucion ETL y los metadatos
ETL_SCHEMA=etl_execution_aws

# CORS (separado por comas)
CORS_ALLOWED_ORIGINS=http://localhost:5173
