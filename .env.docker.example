# Variables para docker-compose. Copiar a ".env" (mismo directorio que
# docker-compose.yml) y llenar con datos reales. NO se versiona.
#
# Estas variables se inyectan en los contenedores AL CREARLOS (docker-compose
# up), no en el build de las imagenes — cambiar un valor aqui + `docker
# compose up -d` alcanza, sin rebuild.

# --- Backend: conexion a PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=readonly_user
DB_PASSWORD=password
DB_NAME=etl_db

# Opcionales (dejar vacios salvo que los necesites)
APP_METADATA_DATABASE_URL=
DATABASE_URL=

# --- Backend: seguridad ---
AUTH_ALLOWED_EMAIL_DOMAIN=lazarza.com.mx
PASSWORD_HASH_ALGORITHM=bcrypt
AUTH_SECRET_KEY=change-me-generate-a-real-one
AUTH_TOKEN_EXPIRE_MINUTES=480
ETL_SCHEMA=etl_execution_aws

# CORS: dominio publico desde el que se sirve el frontend (mismo dominio que
# WEB_PORT/tu proxy externo). En local con docker-compose por defecto:
CORS_ALLOWED_ORIGINS=http://localhost:8080

# --- Backend: general ---
API_ENV=production
LOG_LEVEL=INFO

# --- Frontend ---
# Vacio = el navegador llama /api/... en el mismo origen que sirve el
# frontend (nginx del contenedor "web" hace el proxy interno hacia "api").
# Solo usar una URL absoluta si el API vive en otro dominio/puerto publico.
API_BASE_URL=

# Puerto publicado en el host para el contenedor "web"
WEB_PORT=8080
