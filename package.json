{
  "name": "datasentinel",
  "version": "1.0.0",
  "private": true,
  "description": "DATA SENTINEL - Plataforma web de monitoreo para procesos ETL",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @datasentinel/web",
